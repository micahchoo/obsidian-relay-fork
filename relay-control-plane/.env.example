# relay-control-plane environment
#
# The relay-server-sh container is bundled in docker-compose.yml.
# RELAY_SERVER_AUTH and RELAY_PUBLIC_KEY are pre-generated for this deployment.
# To regenerate: docker exec relay-control-plane-relay-server-sh-1 /app/relay gen-auth --json --key-type EdDSA
# Then update relay.toml [[auth]] public_key and these two values.

RELAY_SERVER_URL=http://relay-server-sh:8080
RELAY_SERVER_AUTH=
RELAY_PUBLIC_KEY=
RELAY_KEY_ID=self_hosted
RELAY_KEY_TYPE=EdDSA

# PocketBase admin account — set before first run
PB_ADMIN_EMAIL=admin@relay.local
PB_ADMIN_PASSWORD=changeme

# GitHub OAuth2 (optional)
# Set these to enable GitHub OAuth login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Set to your public URL if not localhost
PB_PUBLIC_URL=http://localhost:8090
