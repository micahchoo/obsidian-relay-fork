{
  "effectiveness": {
    "name": "api_success_rate", 
    "command": "k6 run --out json=results.json k6-load-test.js 2>&1 | grep '{\"metric\":\"http_req_duration\"' | jq -s '.[0].data.values.p95'",
    "direction": "higher",
    "derived_from": "API success rate under load",
    "baseline": null
  },
  "efficiency": {
    "name": "p95_latency_ms", 
    "command": "k6 run --out json=results.json k6-load-test.js 2>&1 | jq -s '.[0].data.values[\"p(95)\"]'",
    "direction": "lower",
    "derived_from": "p95 response latency under load",
    "baseline": null
  },
  "simplicity": {
    "name": "race_condition_patterns",
    "command": "grep -r 'loaded\\|\\$.*\\.items()' Relay/src/components/*.svelte 2>/dev/null | wc -l",
    "direction": "lower",
    "derived_from": "frontend race condition patterns",
    "baseline": null
  },
  "quality_test_inputs": {
    "paths": ["k6-load-test.js", "Relay/src/"],
    "discovered_at": "Phase 0",
    "notes": "k6 load test + Svelte components with race potential"
  },
  "overrides": [
    {
      "name": "frontend_no_flicker",
      "command": "grep -l '\\.length === 0' Relay/src/components/*.svelte | wc -l",
      "veto_on": "increase",
      "skip_when": "quantitative metrics identical to baseline"
    }
  ],
  "constraints": ["api_success_rate >= 95%", "p95_latency_ms < 500"],
  "discard_history": []
}